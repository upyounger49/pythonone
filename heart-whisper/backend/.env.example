# ===== 环境变量模板 =====
# 复制为 .env.dev（开发）或 .env.prod（生产），填入真实值
# 开发: 直接运行 uvicorn（APP_ENV 默认为 dev，自动加载 .env.dev）
# 生产: docker-compose 中设置 APP_ENV=prod，自动加载 .env.prod
DASHSCOPE_API_KEY=your_dashscope_api_key_here
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./heart_whisper.db
